{
  "info": {
    "_postman_id": "seip-api-collection-v1",
    "name": "Smart Expense Intelligence Platform API",
    "description": "Complete API collection for SEIP microservices. Base URL: http://localhost:8080",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth Service",
      "item": [
        {
          "name": "Register Employee",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john_doe\",\n  \"email\": \"john@seip.com\",\n  \"password\": \"password123\",\n  \"role\": \"ROLE_EMPLOYEE\"\n}"
            }
          }
        },
        {
          "name": "Register Manager",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"manager_jane\",\n  \"email\": \"jane@seip.com\",\n  \"password\": \"password123\",\n  \"role\": \"ROLE_MANAGER\"\n}"
            }
          }
        },
        {
          "name": "Register Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"email\": \"admin@seip.com\",\n  \"password\": \"admin123\",\n  \"role\": \"ROLE_ADMIN\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "  console.log('Tokens saved!');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usernameOrEmail\": \"admin@seip.com\",\n  \"password\": \"admin123\"\n}"
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/auth/logout",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "User Service",
      "item": [
        {
          "name": "Create Department",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/departments",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Engineering\",\n  \"code\": \"ENG\",\n  \"budget\": 5000000\n}"
            }
          }
        },
        {
          "name": "Get All Departments",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/departments"
          }
        },
        {
          "name": "Create Employee",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/employees",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john@seip.com\",\n  \"phone\": \"+91-9876543210\",\n  \"departmentId\": 1,\n  \"designation\": \"Software Engineer\",\n  \"authUserId\": 1,\n  \"employeeCode\": \"EMP001\"\n}"
            }
          }
        },
        {
          "name": "Get All Employees",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/employees?page=0&size=20",
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Assign Manager",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/managers/assign",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employeeId\": 1,\n  \"managerId\": 2\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Expense Service",
      "item": [
        {
          "name": "Get Categories",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/categories"
          }
        },
        {
          "name": "Create Expense (DRAFT)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/expenses",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Client Dinner\",\n  \"description\": \"Dinner with client XYZ\",\n  \"amount\": 2500.00,\n  \"currency\": \"INR\",\n  \"merchantName\": \"The Oberoi Restaurant\",\n  \"expenseDate\": \"2024-12-01\",\n  \"categoryId\": 2,\n  \"items\": [\n    { \"description\": \"Food & Beverages\", \"amount\": 2000.00, \"quantity\": 1 },\n    { \"description\": \"Service Charge\", \"amount\": 500.00, \"quantity\": 1 }\n  ]\n}"
            }
          }
        },
        {
          "name": "Create HIGH RISK Expense",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/expenses",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Miscellaneous Expenses\",\n  \"description\": \"Various misc expenses\",\n  \"amount\": 75000.00,\n  \"currency\": \"INR\",\n  \"merchantName\": \"Unknown Vendor\",\n  \"expenseDate\": \"2024-12-07\",\n  \"categoryId\": 8\n}"
            }
          }
        },
        {
          "name": "Get My Expenses",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/expenses?page=0&size=10",
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Submit Expense",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/expenses/1/submit"
          }
        },
        {
          "name": "Upload Receipt",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/expenses/1/receipts",
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "file", "type": "file", "src": "/path/to/receipt.pdf" }]
            }
          }
        },
        {
          "name": "Manager - Get Approval Queue",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/expenses/manager/queue"
          }
        },
        {
          "name": "Manager - Approve Expense",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/expenses/1/approve",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notes\": \"Approved. All receipts verified.\"\n}"
            }
          }
        },
        {
          "name": "Manager - Reject Expense",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/expenses/1/reject",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"decision\": \"REJECTED\",\n  \"notes\": \"Missing original receipts. Please resubmit with proper documentation.\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Fraud Service",
      "item": [
        {
          "name": "Get Fraud Analysis",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/fraud/analysis/1"
          }
        },
        {
          "name": "Get Fraud Dashboard",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/fraud/dashboard"
          }
        },
        {
          "name": "Get High Risk Expenses",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/fraud/high-risk?page=0&size=10",
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Manual Fraud Analysis",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/fraud/analyze",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"expenseId\": 2,\n  \"employeeId\": 1,\n  \"amount\": 75000.00,\n  \"merchantName\": \"Unknown Vendor\",\n  \"expenseDate\": \"2024-12-07\",\n  \"categoryCode\": \"MISC\",\n  \"categoryId\": 8\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Analytics Service",
      "item": [
        {
          "name": "Organization Summary",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/analytics/summary"
          }
        },
        {
          "name": "Monthly Trends",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/analytics/monthly?year=2024",
              "query": [{ "key": "year", "value": "2024" }]
            }
          }
        },
        {
          "name": "Category Breakdown",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/analytics/categories?from=2024-01-01&to=2024-12-31",
              "query": [
                { "key": "from", "value": "2024-01-01" },
                { "key": "to", "value": "2024-12-31" }
              ]
            }
          }
        },
        {
          "name": "Fraud Trends",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/analytics/fraud-trends?year=2024",
              "query": [{ "key": "year", "value": "2024" }]
            }
          }
        },
        {
          "name": "Top Spenders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/analytics/top-spenders?limit=10",
              "query": [{ "key": "limit", "value": "10" }]
            }
          }
        }
      ]
    },
    {
      "name": "Audit Service",
      "item": [
        {
          "name": "Get Audit Logs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/audit/logs?page=0&size=20",
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get Expense Audit Trail",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/audit/logs/expense/1"
          }
        }
      ]
    },
    {
      "name": "ML Service (Direct)",
      "item": [
        {
          "name": "ML Health Check",
          "request": {
            "method": "GET",
            "url": "http://localhost:8088/health"
          }
        },
        {
          "name": "Predict Fraud Probability",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "http://localhost:8088/ml/predict-fraud",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"expense_id\": 1,\n  \"amount\": 75000.00,\n  \"category_code\": \"MISC\",\n  \"employee_id\": 1,\n  \"monthly_claim_count\": 7,\n  \"frequency_score\": 0.8,\n  \"employee_history_score\": 0.3,\n  \"is_weekend\": true,\n  \"day_of_week\": 6\n}"
            }
          }
        },
        {
          "name": "ML Model Info",
          "request": {
            "method": "GET",
            "url": "http://localhost:8088/ml/model-info"
          }
        }
      ]
    }
  ]
}
