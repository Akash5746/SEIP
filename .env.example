# ─────────────────────────────────────────────
# Smart Expense Intelligence Platform — .env.example
# Copy to .env and fill in real values.
# NEVER commit the actual .env file.
# ─────────────────────────────────────────────

# ─── Database ───
DB_HOST=seip-postgres
DB_PORT=5432
DB_NAME=seip_db
DB_USER=seip_user
DB_PASSWORD=seip_secret_2024

# ─── JWT ───
JWT_SECRET=seip-super-secret-jwt-key-2024-must-be-at-least-64-chars-long-for-hs512

# ─── MinIO / Object Storage ───
MINIO_ENDPOINT=http://seip-minio:9000
MINIO_ACCESS_KEY=seip_minio_user
MINIO_SECRET_KEY=seip_minio_secret

# ─── Email (SMTP) ───
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=noreply@seip.com
MAIL_PASSWORD=changeme

# ─── Grafana ───
GRAFANA_ADMIN_USER=admin
GRAFANA_PASSWORD=seip_grafana_2024

# ─── Kafka ───
KAFKA_SERVERS=seip-kafka:29092

# ─── ML Service ───
ML_SERVICE_URL=http://seip-ml:8088

# ─── Elasticsearch ───
ELASTICSEARCH_HOST=seip-elasticsearch
ELASTICSEARCH_PORT=9200
